# Kubeapps Development Environment Variables
# Copy this file to .env and update with your actual values

# PostgreSQL Configuration for Helm Plugin
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=kubeapps
POSTGRES_USER=your_username
POSTGRES_PASSWORD=your_password

# Kubernetes Configuration
KUBECONFIG=/path/to/your/kubeconfig

# Optional: Override default namespace
POD_NAMESPACE=default

# Global namespace for Helm repositories
GLOBAL_HELM_REPOS_NAMESPACE=default